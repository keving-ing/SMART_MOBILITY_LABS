+def dateparse(tc):
+    # Trasforma la stringa del dizionario in un dizionario Python
+    timestamp_dict = eval(tc)
 
+    # Estrai il valore di "dow" e "hour" dal dizionario
+    dow = timestamp_dict.get("dow", 0)
+    hour = timestamp_dict.get("hour", 0)
 
+    # Calcola il timestamp in secondi
+    timestamp = dow * 24 * 3600 + hour * 3600
+
+    # Converti in un oggetto datetime
+    return pd.to_datetime(timestamp, unit='s')
 
 
